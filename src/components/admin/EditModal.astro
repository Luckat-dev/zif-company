<div id="edit-modal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 3l4 4-7 7H10v-4l7-7z"/>
          <path d="M4 20h16"/>
        </svg>
        Modifier le membre
      </h3>
      <span class="close-modal" onclick="closeEditModal()">&times;</span>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-id" />
      <div class="form-group">
        <label>Nom *</label>
        <input type="text" id="edit-name" class="edit-input" />
      </div>
      <div class="form-group">
        <label>Poste *</label>
        <input type="text" id="edit-role" class="edit-input" />
      </div>
      <div class="form-group">
        <label>Biographie</label>
        <textarea id="edit-bio" class="edit-textarea" rows="3"></textarea>
      </div>
      <div class="form-group">
        <label>WhatsApp</label>
        <input type="text" id="edit-whatsapp" class="edit-input" placeholder="+243851954930" />
        <small style="color:#666;">Format: +243XXXXXXXXX ou 08XXXXXXXXX</small>
      </div>
      <div class="form-group">
        <label>Ordre d'affichage</label>
        <input type="number" id="edit-order" class="edit-input" />
      </div>
      <div class="form-group">
        <label>Photo</label>
        <input type="file" id="edit-photo" accept="image/*" />
        <small>Laissez vide pour garder la photo actuelle</small>
      </div>
      <div id="current-photo-preview" style="margin-top: 10px; display: none;">
        <label>Photo actuelle :</label>
        <img id="current-photo-img" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; margin-top: 5px;" />
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeEditModal()">Annuler</button>
      <button class="btn-save" onclick="saveEdit()">Enregistrer</button>
    </div>
  </div>
</div>

<!-- MODAL DE SUCCÈS -->
<div id="edit-success-modal" class="modal success-modal">
  <div class="modal-content success-content">
    <div class="success-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <h3>Succès !</h3>
    <p id="edit-success-message">Membre modifié avec succès</p>
    <button class="success-btn" onclick="closeEditSuccessModal()">Continuer</button>
  </div>
</div>

<style>
  .modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    justify-content: center;
    align-items: center;
    z-index: 1000;
  }
  .modal-content {
    background: white;
    padding: 25px;
    border-radius: 15px;
    width: 90%;
    max-width: 500px;
    max-height: 90%;
    overflow-y: auto;
  }
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .close-modal {
    font-size: 28px;
    cursor: pointer;
    color: #999;
  }
  .modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 20px;
  }
  .form-group { margin-bottom: 15px; }
  .form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: 600;
    font-size: 13px;
    color: #333;
  }
  .edit-input, .edit-textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
  }
  .btn-cancel { padding: 8px 16px; background: #9CA3AF; color: white; border: none; border-radius: 6px; cursor: pointer; }
  .btn-save { padding: 8px 16px; background: #10B981; color: white; border: none; border-radius: 6px; cursor: pointer; }

  /* MODAL SUCCÈS */
  .success-modal .modal-content {
    text-align: center;
    max-width: 350px;
  }
  .success-icon {
    width: 70px;
    height: 70px;
    background: #10B981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    animation: scaleIn 0.3s ease;
  }
  .success-icon svg { width: 40px; height: 40px; }
  .success-modal h3 { font-size: 24px; color: #333; margin-bottom: 10px; }
  .success-modal p { color: #666; margin-bottom: 25px; }
  .success-btn {
    padding: 10px 30px;
    background: #10B981;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
  }
  @keyframes scaleIn {
    from { transform: scale(0); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase.js';
  
  let currentEditId = null;
  
  function validateWhatsApp(number) {
    if (!number || number.trim() === '') {
      return { valid: true, message: '' };
    }
    
    let cleaned = number.replace(/[\s\-\(\)]/g, '');
    const internationalRegex = /^(\+?243)(8[0-9]{8}|9[0-9]{8})$/;
    const localRegex = /^0(8[0-9]{8}|9[0-9]{8})$/;
    
    if (internationalRegex.test(cleaned)) {
      return { valid: true, message: '' };
    }
    
    if (localRegex.test(cleaned)) {
      const converted = '+243' + cleaned.substring(1);
      return { valid: true, converted: converted, message: '' };
    }
    
    return { 
      valid: false, 
      message: 'Numéro invalide. Utilisez +243XXXXXXXXX ou 08XXXXXXXXX' 
    };
  }
  
  window.openEditModal = async (id) => {
    try {
      const { data: member, error } = await supabase
        .from('team')
        .select('*')
        .eq('id', id)
        .single();
      
      if (error) throw error;
      if (!member) {
        window.showNotification('Membre non trouvé', 'error');
        return;
      }
      
      currentEditId = id;
      document.getElementById('edit-id').value = member.id;
      document.getElementById('edit-name').value = member.name || '';
      document.getElementById('edit-role').value = member.role || '';
      document.getElementById('edit-bio').value = member.bio || '';
      document.getElementById('edit-whatsapp').value = member.whatsapp || '';
      document.getElementById('edit-order').value = member.display_order || 0;
      document.getElementById('edit-photo').value = '';
      
      if (member.photo_url) {
        const previewContainer = document.getElementById('current-photo-preview');
        const previewImg = document.getElementById('current-photo-img');
        previewImg.src = member.photo_url;
        previewContainer.style.display = 'block';
      } else {
        document.getElementById('current-photo-preview').style.display = 'none';
      }
      
      document.getElementById('edit-modal').style.display = 'flex';
    } catch (err) {
      console.error('Error loading member:', err);
      window.showNotification('Erreur lors du chargement du membre', 'error');
    }
  };
  
  window.closeEditModal = () => {
    document.getElementById('edit-modal').style.display = 'none';
    currentEditId = null;
  };
  
  function showEditSuccessModal(message) {
    const modal = document.getElementById('edit-success-modal');
    const msgSpan = document.getElementById('edit-success-message');
    msgSpan.textContent = message;
    modal.style.display = 'flex';
    
    setTimeout(() => {
      closeEditSuccessModal();
    }, 2000);
  }
  
  window.closeEditSuccessModal = () => {
    document.getElementById('edit-success-modal').style.display = 'none';
  };
  
  window.saveEdit = async () => {
    const id = currentEditId;
    const name = document.getElementById('edit-name').value;
    const role = document.getElementById('edit-role').value;
    const bio = document.getElementById('edit-bio').value;
    let whatsapp = document.getElementById('edit-whatsapp').value;
    const order = parseInt(document.getElementById('edit-order').value) || 0;
    const photoFile = document.getElementById('edit-photo').files[0];
    
    const validation = validateWhatsApp(whatsapp);
    if (!validation.valid) {
      window.showNotification(validation.message, 'error');
      return;
    }
    if (validation.converted) {
      whatsapp = validation.converted;
    }
    
    if (!name || !role) {
      window.showNotification('Le nom et le poste sont requis', 'error');
      return;
    }
    
    try {
      const updateData = { name, role, bio, whatsapp, display_order: order };
      if (photoFile) {
        updateData.photo_url = await window.uploadImage(photoFile);
      }
      
      const { error } = await supabase
        .from('team')
        .update(updateData)
        .eq('id', id);
      
      if (error) throw error;
      
      closeEditModal();
      showEditSuccessModal('Membre modifié avec succès !');
      await window.loadMembersList();
    } catch (err) {
      console.error('Error saving member:', err);
      window.showNotification('Erreur: ' + err.message, 'error');
    }
  };
  
  window.onclick = (e) => {
    const editModal = document.getElementById('edit-modal');
    const successModal = document.getElementById('edit-success-modal');
    if (e.target === editModal) closeEditModal();
    if (e.target === successModal) closeEditSuccessModal();
  };
</script>
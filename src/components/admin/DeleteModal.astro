<div id="delete-modal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 7h16M10 11v6M14 11v6M5 7l1 13a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2l1-13"/>
          <path d="M9 3h6a1 1 0 0 1 1 1v3H8V4a1 1 0 0 1 1-1z"/>
        </svg>
        Confirmer la suppression
      </h3>
      <span class="close-modal" onclick="closeDeleteModal()">&times;</span>
    </div>
    <div class="modal-body">
      <p>Êtes-vous sûr de vouloir supprimer ce membre ?</p>
      <p style="color: red; font-size: 14px;">Cette action est irréversible.</p>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeDeleteModal()">Annuler</button>
      <button class="btn-delete" onclick="confirmDelete()">Supprimer</button>
    </div>
  </div>
</div>

<!-- MODAL DE SUCCÈS SUPPRESSION -->
<div id="delete-success-modal" class="modal success-modal">
  <div class="modal-content success-content">
    <div class="success-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <h3>Supprimé !</h3>
    <p id="delete-success-message">Membre supprimé avec succès</p>
    <button class="success-btn" onclick="closeDeleteSuccessModal()">Continuer</button>
  </div>
</div>

<style>
  .modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    justify-content: center;
    align-items: center;
    z-index: 1000;
  }
  .modal-content {
    background: white;
    padding: 25px;
    border-radius: 15px;
    width: 90%;
    max-width: 400px;
  }
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .close-modal {
    font-size: 28px;
    cursor: pointer;
    color: #999;
  }
  .modal-body {
    text-align: center;
    margin-bottom: 20px;
  }
  .modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }
  .btn-cancel { padding: 8px 16px; background: #9CA3AF; color: white; border: none; border-radius: 6px; cursor: pointer; }
  .btn-delete { padding: 8px 16px; background: #EF4444; color: white; border: none; border-radius: 6px; cursor: pointer; }

  /* MODAL DE SUCCÈS */
  .success-modal .modal-content {
    text-align: center;
    max-width: 350px;
  }
  .success-icon {
    width: 70px;
    height: 70px;
    background: #10B981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    animation: scaleIn 0.3s ease;
  }
  .success-icon svg { width: 40px; height: 40px; }
  .success-modal h3 { font-size: 24px; color: #333; margin-bottom: 10px; }
  .success-modal p { color: #666; margin-bottom: 25px; }
  .success-btn {
    padding: 10px 30px;
    background: #10B981;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
  }
  @keyframes scaleIn {
    from { transform: scale(0); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
</style>

<script>
  let currentDeleteId = null;
  
  window.openDeleteModal = (id) => {
    currentDeleteId = id;
    document.getElementById('delete-modal').style.display = 'flex';
  };
  
  window.closeDeleteModal = () => {
    document.getElementById('delete-modal').style.display = 'none';
    currentDeleteId = null;
  };
  
  function showDeleteSuccessModal(message) {
    const modal = document.getElementById('delete-success-modal');
    const msgSpan = document.getElementById('delete-success-message');
    msgSpan.textContent = message;
    modal.style.display = 'flex';
    
    setTimeout(() => {
      closeDeleteSuccessModal();
    }, 2000);
  }
  
  window.closeDeleteSuccessModal = () => {
    document.getElementById('delete-success-modal').style.display = 'none';
  };
  
  window.confirmDelete = async () => {
    if (!currentDeleteId) return;
    try {
      await window.deleteMember(currentDeleteId);
      closeDeleteModal();
      showDeleteSuccessModal('Membre supprimé avec succès !');
    } catch (err) {
      window.showNotification('Erreur: ' + err.message, 'error');
    }
  };
  
  window.onclick = (e) => {
    const deleteModal = document.getElementById('delete-modal');
    const successModal = document.getElementById('delete-success-modal');
    if (e.target === deleteModal) closeDeleteModal();
    if (e.target === successModal) closeDeleteSuccessModal();
  };
</script>
<div class="projects-container">
  <!-- Formulaire d'ajout -->
  <div class="form-card">
    <div class="card-title">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="M8 9h8"/>
        <path d="M8 13h6"/>
        <path d="M2 8h20"/>
        <line x1="16" y1="3" x2="22" y2="3"/>
        <line x1="19" y1="6" x2="19" y2="0"/>
      </svg>
      <h2>Ajouter un projet</h2>
    </div>
    
    <form id="add-project-form">
      <div class="form-row">
        <div class="form-group">
          <label>Titre *</label>
          <input type="text" id="project-title" placeholder="Ex: Escalier hélicoïdal" required />
        </div>
        <div class="form-group">
          <label>Catégorie *</label>
          <input type="text" id="project-categorie" placeholder="Ex: Design & Conception" required />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Ville</label>
          <input type="text" id="project-ville" placeholder="Ex: Goma" />
        </div>
        <div class="form-group">
          <label>Année</label>
          <input type="text" id="project-annee" placeholder="Ex: 2026" />
        </div>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea id="project-description" rows="3" placeholder="Description du projet..."></textarea>
      </div>
      <div class="form-group">
        <label>Photo *</label>
        <input type="file" id="project-image" accept="image/*" required />
        <small>Format recommandé: 800x600px</small>
      </div>
      <button type="submit" class="submit-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M20 14.66V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h5.34"/>
          <polygon points="18 2 22 6 12 16 8 16 8 12 18 2"/>
        </svg>
        Ajouter le projet
      </button>
    </form>
  </div>

  <!-- Liste des projets -->
  <div class="list-card">
    <div class="card-title">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="M8 9h8"/>
        <path d="M8 13h6"/>
        <path d="M2 8h20"/>
      </svg>
      <h2>Liste des projets</h2>
      <span class="badge" id="projects-count">0</span>
    </div>
    <div id="projects-list" class="projects-list"></div>
  </div>
</div>

<!-- MODAL SUCCÈS -->
<div id="success-modal" class="modal success-modal">
  <div class="modal-content success-content">
    <div class="success-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <h3>Succès !</h3>
    <p id="success-message">Opération réussie</p>
    <button class="success-btn" onclick="closeSuccessModal()">Continuer</button>
  </div>
</div>

<!-- MODAL ERREUR -->
<div id="error-modal" class="modal error-modal">
  <div class="modal-content error-content">
    <div class="error-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <h3>Erreur</h3>
    <p id="error-message">Une erreur est survenue</p>
    <button class="error-btn" onclick="closeErrorModal()">Fermer</button>
  </div>
</div>

<style>
  .projects-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 25px;
  }
  
  .form-card, .list-card {
    background: white;
    border-radius: 20px;
    padding: 24px;
    margin-bottom: 30px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    border: 1px solid #eef2f6;
  }
  
  .card-title {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid #f0f2f5;
  }
  
  .card-title h2 {
    font-size: 18px;
    color: #1e293b;
    margin: 0;
  }
  
  .badge {
    background: linear-gradient(135deg, #3B82F6, #2563EB);
    color: white;
    padding: 4px 12px;
    border-radius: 30px;
    font-size: 13px;
    font-weight: 600;
    margin-left: auto;
  }
  
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }
  
  .form-group {
    margin-bottom: 15px;
  }
  
  .form-group label {
    display: block;
    margin-bottom: 6px;
    font-weight: 600;
    font-size: 13px;
    color: #333;
  }
  
  .form-group input, .form-group textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
  }
  
  .submit-btn {
    width: 100%;
    padding: 12px;
    background: #10B981;
    color: white;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-height: 550px;
    overflow-y: auto;
  }
  
  .project-item {
    background: #f9f9f9;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all 0.2s;
  }
  
  .project-item:hover {
    border-color: #3B82F6;
    box-shadow: 0 2px 8px rgba(59,130,246,0.1);
  }
  
  .project-item img {
    width: 35px !important;
    height: 35px !important;
    min-width: 35px !important;
    max-width: 35px !important;
    object-fit: cover;
    border-radius: 8px;
  }
  
  .project-info {
    flex: 1;
  }
  
  .project-info h4 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 3px;
    color: #1e293b;
  }
  
  .project-info p {
    font-size: 11px;
    color: #64748b;
    margin: 2px 0;
  }
  
  .project-date {
    font-size: 10px;
    color: #3B82F6;
    margin-top: 3px;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  
  .project-actions {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }
  
  .edit-btn, .delete-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px 10px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 11px;
    font-weight: 500;
  }
  
  .edit-btn {
    background: #F59E0B;
    color: white;
  }
  
  .delete-btn {
    background: #EF4444;
    color: white;
  }

  /* MODALS */
  .modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    justify-content: center;
    align-items: center;
    z-index: 1000;
  }
  
  .success-modal .modal-content, .error-modal .modal-content {
    text-align: center;
    max-width: 350px;
    background: white;
    padding: 25px;
    border-radius: 15px;
  }
  
  .success-icon {
    width: 70px;
    height: 70px;
    background: #10B981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    animation: scaleIn 0.3s ease;
  }
  
  .error-icon {
    width: 70px;
    height: 70px;
    background: #EF4444;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    animation: scaleIn 0.3s ease;
  }
  
  .success-icon svg, .error-icon svg {
    width: 40px;
    height: 40px;
  }
  
  .success-modal h3, .error-modal h3 {
    font-size: 24px;
    color: #333;
    margin-bottom: 10px;
  }
  
  .success-modal p, .error-modal p {
    color: #666;
    margin-bottom: 25px;
  }
  
  .success-btn {
    padding: 10px 30px;
    background: #10B981;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
  }
  
  .error-btn {
    padding: 10px 30px;
    background: #EF4444;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
  }
  
  @keyframes scaleIn {
    from { transform: scale(0); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  @media (max-width: 768px) {
    .projects-container {
      padding: 15px;
    }
    .form-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .project-item {
      flex-wrap: wrap;
      justify-content: center;
      text-align: center;
    }
    .project-actions {
      width: 100%;
      justify-content: center;
      margin-top: 8px;
    }
    .project-item img {
      width: 40px !important;
      height: 40px !important;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase';

  let currentProjects = [];

  window.showSuccessModal = (message) => {
    const modal = document.getElementById('success-modal');
    const msgSpan = document.getElementById('success-message');
    msgSpan.textContent = message;
    modal.style.display = 'flex';
    setTimeout(() => closeSuccessModal(), 2000);
  };

  window.closeSuccessModal = () => {
    document.getElementById('success-modal').style.display = 'none';
  };

  window.showErrorModal = (message) => {
    const modal = document.getElementById('error-modal');
    const msgSpan = document.getElementById('error-message');
    msgSpan.textContent = message;
    modal.style.display = 'flex';
  };

  window.closeErrorModal = () => {
    document.getElementById('error-modal').style.display = 'none';
  };

  window.loadProjectsList = async () => {
    const { data: projects, error } = await supabase
      .from('projects')
      .select('*')
      .order('created_at', { ascending: false });
    
    if (error) {
      showErrorModal('Erreur lors du chargement');
      return;
    }
    
    currentProjects = projects || [];
    renderProjects();
  };

  function formatDate(dateString) {
    if (!dateString) return '';
    const date = new Date(dateString);
    return date.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
  }

  function renderProjects() {
    const container = document.getElementById('projects-list');
    const countSpan = document.getElementById('projects-count');
    
    if (!container) return;
    
    if (!currentProjects.length) {
      container.innerHTML = '<div class="empty-state" style="text-align:center;padding:40px;color:#999;"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M8 9h8"/><path d="M8 13h6"/><path d="M2 8h20"/></svg><br/>Aucun projet</div>';
      if (countSpan) countSpan.textContent = '0';
      return;
    }
    
    if (countSpan) countSpan.textContent = currentProjects.length;
    
    container.innerHTML = currentProjects.map(p => `
      <div class="project-item">
        <img src="${p.image_url || 'https://placehold.co/35x35'}" alt="${escapeHtml(p.title)}" />
        <div class="project-info">
          <h4>${escapeHtml(p.title)}</h4>
          <p><strong>${escapeHtml(p.categorie)}</strong> | ${escapeHtml(p.ville || '')} | ${escapeHtml(p.annee || '')}</p>
          <p>${escapeHtml(p.description?.substring(0, 80))}${p.description?.length > 80 ? '...' : ''}</p>
          <div class="project-date">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Publié le ${formatDate(p.created_at)}
          </div>
        </div>
        <div class="project-actions">
          <button class="edit-btn" onclick="openEditProjectModal(${p.id})">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M17 3l4 4-7 7H10v-4l7-7z"/>
              <path d="M4 20h16"/>
            </svg>
            Modifier
          </button>
          <button class="delete-btn" onclick="openDeleteProjectModal(${p.id})">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M4 7h16M10 11v6M14 11v6M5 7l1 13a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2l1-13"/>
              <path d="M9 3h6a1 1 0 0 1 1 1v3H8V4a1 1 0 0 1 1-1z"/>
            </svg>
            Supprimer
          </button>
        </div>
      </div>
    `).join('');
  }

  async function uploadImage(file) {
    const fileName = Date.now() + '_' + file.name;
    const { error } = await supabase.storage
      .from('team-photos')
      .upload('projects/' + fileName, file);
    if (error) throw error;
    const { data: { publicUrl } } = supabase.storage
      .from('team-photos')
      .getPublicUrl('projects/' + fileName);
    return publicUrl;
  }

  // Ajouter un projet
  document.getElementById('add-project-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const title = document.getElementById('project-title').value;
    const categorie = document.getElementById('project-categorie').value;
    const ville = document.getElementById('project-ville').value;
    const annee = document.getElementById('project-annee').value;
    const description = document.getElementById('project-description').value;
    const imageFile = document.getElementById('project-image').files[0];
    
    if (!title || !categorie) {
      showErrorModal('Titre et catégorie requis');
      return;
    }
    if (!imageFile) {
      showErrorModal('Photo requise');
      return;
    }
    
    try {
      const imageUrl = await uploadImage(imageFile);
      await supabase.from('projects').insert({
        title, 
        categorie, 
        ville, 
        annee, 
        description, 
        image_url: imageUrl
      });
      showSuccessModal('Projet ajouté avec succès !');
      document.getElementById('add-project-form').reset();
      window.loadProjectsList();
    } catch (err) {
      showErrorModal(err.message);
    }
  });

  // Chargement initial
  window.loadProjectsList();
  
  // Fermer modals en cliquant à l'extérieur
  window.onclick = (e) => {
    if (e.target === document.getElementById('success-modal')) closeSuccessModal();
    if (e.target === document.getElementById('error-modal')) closeErrorModal();
  };

  function escapeHtml(text) { 
    if (!text) return ''; 
    const div = document.createElement('div'); 
    div.textContent = text; 
    return div.innerHTML; 
  }
</script>
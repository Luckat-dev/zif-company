---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Inscription confirmée">
  <div style="text-align: center; padding: 100px 0;">
    <div style="width: 80px; height: 80px; background: #3B82F6; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 30px;">
      <svg viewBox="0 0 24 24" width="40" height="40" fill="white"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
    </div>
    <h1 style="font-size: 2.5rem; margin-bottom: 20px;">Merci !</h1>
    <p style="font-size: 1.2rem; color: #64748B;">Votre inscription à notre newsletter a bien été enregistrée.</p>
    <a href="/" style="display: inline-block; margin-top: 30px; color: #3B82F6; font-weight: 600;">← Retour à l'accueil</a>
  </div>
</BaseLayout>
---
import BaseLayout from '../layouts/BaseLayout.astro';

const companyName = "ZIF COMPANY";
const slogan = "Centre de Formation & Services Techniques";
const badge = "RDC · EXCELLENCE TECHNIQUE";

const domaines = [
  { 
    icon: "fa-industry", 
    title: "Soudure & Construction métallique", 
    number: "01",
    description: "Charpentes, portails, escaliers, garde-corps et structures métalliques sur mesure. Nous maîtrisons les techniques de soudure à l'arc, MIG/MAG et TIG pour tous types de métaux."
  },
  { 
    icon: "fa-couch", 
    title: "Fabrication de meubles métalliques", 
    number: "02",
    description: "Mobilier design industriel, tables, chaises, étagères et rangements en acier. Chaque pièce est unique, alliant robustesse et esthétique contemporaine."
  },
  { 
    icon: "fa-gear", 
    title: "Ajustage & Maintenance industrielle", 
    number: "03",
    description: "Réparation de pièces mécaniques, maintenance préventive et corrective d'équipements industriels. Intervention rapide sur site pour minimiser vos arrêts de production."
  },
  { 
    icon: "fa-pen-ruler", 
    title: "Design & conception technique", 
    number: "04",
    description: "De l'esquisse au plan technique 3D, nous concevons vos projets avec précision. Études de faisabilité, choix des matériaux et optimisation des coûts."
  },
  { 
    icon: "fa-chalkboard-user", 
    title: "Travaux pratiques & formation professionnelle", 
    number: "05",
    description: "Formation certifiante aux métiers de la soudure. Ateliers pratiques, théorie et accompagnement personnalisé pour former la prochaine génération de soudeurs qualifiés."
  }
];

const avantages = [
  { 
    icon: "fa-graduation-cap", 
    title: "Formation pratique et professionnelle",
    description: "Des formateurs certifiés avec plus de 10 ans d'expérience terrain. 80% de pratique, 20% de théorie."
  },
  { 
    icon: "fa-user-gear", 
    title: "Encadrement par des experts",
    description: "Notre équipe est composée de soudeurs qualifiés, formés aux normes internationales et passionnés par leur métier."
  },
  { 
    icon: "fa-microchip", 
    title: "Matériels modernes",
    description: "Postes à souder dernière génération, équipements de protection individuelle haut de gamme et outillage de précision."
  },
  { 
    icon: "fa-award", 
    title: "Certification après formation",
    description: "Attestation de fin de formation reconnue par les professionnels du secteur. Un vrai tremplin pour votre carrière."
  },
  { 
    icon: "fa-people-group", 
    title: "Accompagnement des projets",
    description: "Du devis à la livraison, un chef de projet dédié vous suit et vous conseille à chaque étape de votre réalisation."
  }
];

const stats = [
  { icon: "fa-calendar-check", value: "10+", label: "Années d'expérience" },
  { icon: "fa-diagram-project", value: "500+", label: "Projets réalisés" },
  { icon: "fa-building-user", value: "15+", label: "Grands comptes" },
  { icon: "fa-face-smile", value: "100%", label: "Clients satisfaits" }
];

const villes = ["Bukavu", "Goma", "Kinshasa"];
const contactPhone = "+243 851 954 930";
const contactEmail = "zifcompany@email.com";

const socialLinks = [
  { icon: "facebook", url: "#" },
  { icon: "instagram", url: "#" },
  { icon: "linkedin", url: "#" },
  { icon: "whatsapp", url: "#" }
];

const navLinks = [
  { text: "Accueil", url: "/" },
  { text: "Équipe", url: "/equipe" },
  { text: "Projets", url: "/projets" },
  { text: "Contact", url: "/contact" }
];

// CHARGEMENT DYNAMIQUE DES PROJETS
const allProjets = import.meta.glob('../content/projets/*.md', { eager: true });
const projetsRecents = Object.values(allProjets)
  .sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date))
  .slice(0, 3);
---

<BaseLayout title="Accueil">
  
  <style>
    :root {
      --accent-primary: #3B82F6;
      --accent-secondary: #1D4ED8;
      --accent-glow: rgba(59, 130, 246, 0.3);
      --bg-dark-accent: #0F172A;
      --text-light: #FFFFFF;
      --font-title: 'Poppins', sans-serif;
      --font-body: 'Inter', sans-serif;
    }

/* ===== HERO SECTION ===== */
.hero {
  padding: 40px 0;
  margin-top: -40px;
}

.hero-video-container {
  max-width: 1200px;
  margin: 0 auto;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

.hero-video-container video {
  width: 100%;
  height: auto;
  display: block;
  
  /* Propriétés légères et compatibles pour améliorer le rendu */
  filter: contrast(1.05) brightness(1.02);
}

/* Suppression de tout overlay ou texte */
.hero::before {
  display: none;
}

.hero-content {
  display: none;
}
    /* ===== WELCOME SECTION ===== */
    .welcome-section {
      padding: 80px 0 60px;
      background: #FFFFFF;
      position: relative;
    }

    body.dark-theme .welcome-section {
      background: #0F172A;
    }

    .welcome-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-primary), transparent);
    }

    .welcome-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 50px;
      align-items: start;
    }

    .welcome-content {
      animation: fadeInUp 0.8s ease;
    }

    .welcome-badge {
      display: inline-flex;
      align-items: center;
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--accent-primary);
      margin-bottom: 20px;
      padding: 6px 16px;
      background: rgba(59, 130, 246, 0.08);
      border-radius: 30px;
      border: 1px solid rgba(59, 130, 246, 0.15);
    }

    .welcome-badge svg {
      fill: var(--accent-primary);
    }

    .welcome-title {
      font-family: var(--font-title);
      font-size: 2.3rem;
      font-weight: 700;
      line-height: 1.3;
      color: #0F172A;
      margin-bottom: 25px;
    }

    body.dark-theme .welcome-title {
      color: white;
    }

    .welcome-text {
      font-size: 1rem;
      line-height: 1.8;
      color: #475569;
      margin-bottom: 20px;
    }

    body.dark-theme .welcome-text {
      color: #94A3B8;
    }

    .welcome-text strong {
      color: var(--accent-primary);
      font-weight: 700;
    }

    .welcome-features {
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin-top: 30px;
    }

    .feature-item {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 500;
      color: #1E293B;
    }

    body.dark-theme .feature-item {
      color: #E2E8F0;
    }

    .feature-item svg {
      fill: var(--accent-primary);
      flex-shrink: 0;
    }

    .welcome-highlight {
      animation: fadeInUp 0.8s ease 0.2s both;
    }

    .highlight-card {
      background: linear-gradient(135deg, #F8FAFC 0%, #EFF6FF 100%);
      padding: 35px 30px;
      border-radius: 20px;
      border: 1px solid rgba(59, 130, 246, 0.12);
      box-shadow: 0 15px 30px rgba(0,0,0,0.04);
    }

    body.dark-theme .highlight-card {
      background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
      border-color: rgba(59, 130, 246, 0.15);
    }

    .highlight-icon {
      width: 60px;
      height: 60px;
      background: var(--accent-primary);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }

    .highlight-icon svg {
      fill: white;
    }

    .highlight-card h3 {
      font-family: var(--font-title);
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 12px;
      color: #0F172A;
    }

    body.dark-theme .highlight-card h3 {
      color: white;
    }

    .highlight-card p {
      color: #64748B;
      margin-bottom: 18px;
      font-size: 0.95rem;
    }

    .highlight-list {
      list-style: none;
    }

    .highlight-list li {
      padding: 10px 0;
      color: #334155;
      font-weight: 500;
      font-size: 0.95rem;
      border-bottom: 1px solid rgba(59, 130, 246, 0.08);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    body.dark-theme .highlight-list li {
      color: #CBD5E1;
    }

    .highlight-list li:last-child {
      border-bottom: none;
    }

    .highlight-list svg {
      fill: var(--accent-primary);
      flex-shrink: 0;
    }

    /* ===== STATS SECTION ===== */
    .stats-section {
      background: var(--bg-dark-accent);
      padding: 70px 0;
      color: white;
      position: relative;
      overflow: hidden;
    }

    .stats-section::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -10%;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(59,130,246,0.1) 0%, transparent 70%);
      border-radius: 50%;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 40px;
      text-align: center;
      position: relative;
      z-index: 2;
    }

    .stat-item {
      padding: 20px;
      transition: transform 0.3s;
    }

    .stat-item:hover {
      transform: translateY(-5px);
    }

    .stat-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 20px;
      background: rgba(59, 130, 246, 0.1);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid rgba(59, 130, 246, 0.3);
    }

    .stat-icon svg {
      width: 40px;
      height: 40px;
      fill: var(--accent-primary);
    }

    .stat-value {
      font-family: var(--font-title);
      font-size: 3.5rem;
      font-weight: 800;
      margin-bottom: 8px;
      background: linear-gradient(135deg, #FFFFFF, #93C5FD);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .stat-label {
      font-size: 1.1rem;
      opacity: 0.9;
      font-weight: 500;
    }

    /* ===== SECTIONS GÉNÉRALES ===== */
    .section {
      padding: 100px 0;
      position: relative;
    }

    .section-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .section-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
      border-radius: 20px;
      margin-bottom: 20px;
      transform: rotate(6deg);
      transition: transform 0.3s;
      box-shadow: 0 10px 25px rgba(59, 130, 246, 0.25);
    }

    .section-icon:hover {
      transform: rotate(0deg) scale(1.05);
    }

    .section-icon svg {
      width: 35px;
      height: 35px;
      fill: white;
    }

    .section-title {
      font-family: var(--font-title);
      font-size: 3.2rem;
      font-weight: 700;
      color: #0F172A;
      margin-bottom: 15px;
      letter-spacing: -0.5px;
      position: relative;
      display: inline-block;
    }

    .section-title::after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 50%;
      transform: translateX(-50%);
      width: 80px;
      height: 4px;
      background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
      border-radius: 2px;
    }

    body.dark-theme .section-title {
      color: white;
    }

    .section-subtitle {
      font-size: 1.2rem;
      color: #64748B;
      max-width: 600px;
      margin: 25px auto 0;
    }

    /* ===== DOMAINES GRID ===== */
    .domaines-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 30px;
    }

    .domaine-card {
      background: #FFFFFF;
      padding: 40px 30px;
      border-radius: 20px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.05);
      border: 1px solid #F1F5F9;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }

    body.dark-theme .domaine-card {
      background: #1E293B;
      border-color: #334155;
    }

    .domaine-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 6px;
      height: 0;
      background: linear-gradient(180deg, var(--accent-primary), var(--accent-secondary));
      transition: height 0.4s ease;
    }

    .domaine-card:hover {
      transform: translateY(-12px);
      box-shadow: 0 30px 60px rgba(59, 130, 246, 0.15);
    }

    .domaine-card:hover::before {
      height: 100%;
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 15px;
      margin-bottom: 20px;
    }

    .card-icon {
      width: 60px;
      height: 60px;
      background: #EFF6FF;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    body.dark-theme .card-icon {
      background: #1E3A5F;
    }

    .card-icon svg {
      width: 32px;
      height: 32px;
      fill: var(--accent-primary);
    }

    .card-number {
      font-family: var(--font-title);
      font-size: 3rem;
      font-weight: 800;
      color: rgba(59, 130, 246, 0.15);
      margin-left: auto;
    }

    .domaine-card h3 {
      font-family: var(--font-title);
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 15px;
      color: #0F172A;
    }

    body.dark-theme .domaine-card h3 {
      color: white;
    }

    .domaine-card p {
      color: #64748B;
      line-height: 1.7;
      font-size: 1rem;
    }

    body.dark-theme .domaine-card p {
      color: #94A3B8;
    }

    /* ===== RÉALISATIONS SECTION ===== */
    .realisations-section {
      background: #F8FAFC;
    }

    body.dark-theme .realisations-section {
      background: #0F172A;
    }

    .realisations-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }

    .realisation-card {
      background: #FFFFFF;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
      border: 1px solid #E5E7EB;
      transition: all 0.3s ease;
    }

    body.dark-theme .realisation-card {
      background: #1E293B;
      border-color: #334155;
    }

    .realisation-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 20px 40px rgba(59, 130, 246, 0.15);
      border-color: var(--accent-primary);
    }

    .realisation-image {
      width: 100%;
      height: 240px;
      overflow: hidden;
    }

    .realisation-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .realisation-card:hover .realisation-image img {
      transform: scale(1.05);
    }

    .realisation-content {
      padding: 25px;
    }

    .realisation-categorie {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--accent-primary);
      margin-bottom: 10px;
    }

    .realisation-card h3 {
      font-family: var(--font-title);
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 12px;
      color: #0F172A;
      line-height: 1.4;
    }

    body.dark-theme .realisation-card h3 {
      color: white;
    }

    .realisation-description {
      color: #64748B;
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 20px;
    }

    body.dark-theme .realisation-description {
      color: #94A3B8;
    }

    .realisation-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 15px;
      border-top: 1px solid #E5E7EB;
    }

    body.dark-theme .realisation-meta {
      border-top-color: #334155;
    }

    .realisation-ville {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 0.85rem;
      color: #64748B;
    }

    .realisation-ville svg {
      fill: var(--accent-primary);
    }

    .realisation-date {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--accent-primary);
    }

    /* ===== MISSION SECTION ===== */
    .mission-section {
      background: linear-gradient(135deg, #F8FAFC 0%, #EFF6FF 100%);
      padding: 100px 0;
      position: relative;
      overflow: hidden;
    }

    body.dark-theme .mission-section {
      background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);
    }

    .mission-section::before {
      content: '';
      position: absolute;
      bottom: -100px;
      left: -100px;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(59,130,246,0.1) 0%, transparent 70%);
      border-radius: 50%;
    }

    .mission-section::after {
      content: '';
      position: absolute;
      top: -50px;
      right: -50px;
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, transparent 70%);
      border-radius: 50%;
    }

    .mission-content {
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
      position: relative;
      z-index: 2;
    }

    .mission-icon {
      width: 90px;
      height: 90px;
      margin: 0 auto 30px;
      background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
      border-radius: 25px;
      display: flex;
      align-items: center;
      justify-content: center;
      transform: rotate(45deg);
      box-shadow: 0 15px 30px rgba(59, 130, 246, 0.3);
    }

    .mission-icon svg {
      width: 45px;
      height: 45px;
      fill: white;
      transform: rotate(-45deg);
    }

    .mission-text {
      font-size: 2.5rem;
      line-height: 1.4;
      font-weight: 700;
      margin-bottom: 20px;
      color: #0F172A;
    }

    body.dark-theme .mission-text {
      color: white;
    }

    .mission-subtext {
      font-size: 1.3rem;
      color: #64748B;
      font-weight: 400;
    }

    /* ===== AVANTAGES GRID ===== */
    .avantages-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
    }

    .avantage-card {
      background: #FFFFFF;
      padding: 35px 25px;
      border-radius: 20px;
      box-shadow: 0 15px 30px rgba(0,0,0,0.05);
      border: 1px solid #F1F5F9;
      transition: all 0.3s;
      text-align: center;
    }

    body.dark-theme .avantage-card {
      background: #1E293B;
      border-color: #334155;
    }

    .avantage-card:hover {
      transform: scale(1.02);
      box-shadow: 0 25px 50px rgba(59, 130, 246, 0.12);
      border-color: var(--accent-primary);
    }

    .avantage-icon {
      width: 75px;
      height: 75px;
      margin: 0 auto 20px;
      background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 20px rgba(59, 130, 246, 0.2);
    }

    .avantage-icon svg {
      width: 35px;
      height: 35px;
      fill: white;
    }

    .avantage-card h3 {
      font-family: var(--font-title);
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 12px;
      color: #0F172A;
    }

    body.dark-theme .avantage-card h3 {
      color: white;
    }

    .avantage-card p {
      color: #64748B;
      line-height: 1.6;
      font-size: 0.95rem;
    }

    /* ===== LOCALISATION SECTION ===== */
    .localisation-section {
      background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);
      color: white;
      padding: 80px 0;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .localisation-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 5L55 50H5L30 5z' fill='rgba(59,130,246,0.03)'/%3E%3C/svg%3E");
      opacity: 0.5;
    }

    .localisation-icon {
      width: 90px;
      height: 90px;
      margin: 0 auto 30px;
      background: rgba(255,255,255,0.08);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid rgba(255,255,255,0.15);
      position: relative;
      z-index: 2;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .localisation-icon svg {
      width: 45px;
      height: 45px;
      fill: var(--accent-primary);
    }

    .localisation-section h2 {
      font-size: 3rem;
      font-weight: 700;
      margin-bottom: 40px;
      position: relative;
      z-index: 2;
    }

    .villes-list {
      display: flex;
      justify-content: center;
      gap: 60px;
      flex-wrap: wrap;
      margin: 40px 0;
      position: relative;
      z-index: 2;
    }

    .ville-item {
      font-size: 2.2rem;
      font-weight: 700;
      font-family: var(--font-title);
      letter-spacing: 2px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .ville-item svg {
      width: 28px;
      height: 28px;
      fill: var(--accent-primary);
    }

    .contact-info-large {
      font-size: 1.4rem;
      margin: 30px 0;
      position: relative;
      z-index: 2;
      display: flex;
      justify-content: center;
      gap: 40px;
      flex-wrap: wrap;
    }

    .contact-info-large svg {
      width: 22px;
      height: 22px;
      fill: var(--accent-primary);
      margin-right: 8px;
    }

    .quote {
      margin-top: 40px;
      font-style: italic;
      opacity: 0.9;
      font-size: 1.2rem;
      position: relative;
      z-index: 2;
    }

    /* ===== FOOTER ===== */
    .footer {
      background: #0A0F1A;
      color: #94A3B8;
      padding: 60px 0 30px;
      position: relative;
    }

    .footer::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary), var(--accent-primary));
    }

    .footer-content {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 40px;
      margin-bottom: 50px;
    }

    .footer-section h3 {
      color: white;
      font-family: var(--font-title);
      font-size: 1.3rem;
      font-weight: 600;
      margin-bottom: 25px;
      position: relative;
      display: inline-block;
    }

    .footer-section h3::after {
      content: '';
      position: absolute;
      bottom: -8px;
      left: 0;
      width: 40px;
      height: 3px;
      background: var(--accent-primary);
      border-radius: 2px;
    }

    .footer-section p {
      line-height: 1.7;
      margin-bottom: 20px;
    }

    .footer-links {
      list-style: none;
    }

    .footer-links li {
      margin-bottom: 12px;
    }

    .footer-links a {
      color: #94A3B8;
      text-decoration: none;
      transition: color 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .footer-links a svg {
      width: 12px;
      height: 12px;
      fill: var(--accent-primary);
    }

    .footer-links a:hover {
      color: white;
    }

    .social-links {
      display: flex;
      gap: 12px;
      margin-top: 20px;
    }

    .social-link {
      width: 40px;
      height: 40px;
      background: rgba(255,255,255,0.05);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #94A3B8;
      text-decoration: none;
      transition: all 0.3s;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .social-link svg {
      width: 20px;
      height: 20px;
      fill: currentColor;
    }

    .social-link:hover {
      background: var(--accent-primary);
      color: white;
      transform: translateY(-3px);
    }

    .contact-info-footer {
      list-style: none;
    }

    .contact-info-footer li {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 15px;
      color: #94A3B8;
    }

    .contact-info-footer svg {
      width: 18px;
      height: 18px;
      fill: var(--accent-primary);
    }

    .footer-bottom {
      text-align: center;
      padding-top: 30px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .footer-bottom p {
      color: #64748B;
      font-size: 0.95rem;
    }

    .footer-bottom .signature {
      color: var(--accent-primary);
      font-weight: 600;
      margin-top: 10px;
    }

    .footer-bottom .signature svg {
      width: 16px;
      height: 16px;
      fill: #EF4444;
      margin: 0 5px;
    }

    /* ===== BOUTONS ===== */
    .btn {
      display: inline-block;
      padding: 16px 40px;
      background: var(--accent-primary);
      color: white;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      border-radius: 50px;
      transition: all 0.3s;
      border: none;
      cursor: pointer;
      box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3);
    }

    .btn:hover {
      background: var(--accent-secondary);
      transform: translateY(-3px);
      box-shadow: 0 12px 30px rgba(59, 130, 246, 0.4);
    }

    .btn-outline {
      background: transparent;
      border: 2px solid white;
      box-shadow: none;
    }

    .btn-outline:hover {
      background: white;
      color: var(--accent-primary);
    }

    .btn-white {
      background: white;
      color: var(--accent-primary);
      box-shadow: 0 8px 20px rgba(255,255,255,0.2);
    }

    .btn-white:hover {
      background: #F8FAFC;
    }

    .btn svg {
      width: 16px;
      height: 16px;
      fill: currentColor;
      margin-left: 10px;
    }

    /* ===== ANIMATIONS ===== */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(40px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 992px) {
      .welcome-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }
      .footer-content {
        grid-template-columns: repeat(2, 1fr);
      }
      .realisations-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .hero h1 { font-size: 3.2rem; }
      .hero-slogan { font-size: 1.2rem; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
      .stat-value { font-size: 2.5rem; }
      .section-title { font-size: 2.5rem; }
      .mission-text { font-size: 1.8rem; }
      .ville-item { font-size: 1.5rem; }
      .contact-info-large { font-size: 1.1rem; gap: 20px; }
      .footer-content {
        grid-template-columns: 1fr;
        gap: 30px;
      }
      .realisations-grid {
        grid-template-columns: 1fr;
      }
      .welcome-title {
        font-size: 1.9rem;
      }
    }

    @media (max-width: 480px) {
      .stats-grid { grid-template-columns: 1fr; }
      .hero-buttons { flex-direction: column; }
    }
  </style>


---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Erreur">
  <div style="text-align: center; padding: 100px 0;">
    <h1 style="font-size: 2.5rem; margin-bottom: 20px;">Oups...</h1>
    <p style="font-size: 1.2rem; color: #64748B;">Une erreur est survenue lors de votre inscription.</p>
    <p style="margin-top: 20px;">Veuillez réessayer plus tard ou nous contacter directement.</p>
    <a href="/" style="display: inline-block; margin-top: 30px; color: #3B82F6; font-weight: 600;">← Retour à l'accueil</a>
  </div>
</BaseLayout>